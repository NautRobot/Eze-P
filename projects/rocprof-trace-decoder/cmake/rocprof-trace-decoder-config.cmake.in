@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Threads)

# Re-find the disasm backend the decoder was built against, so its transitive
# include dirs and link libs are usable from the consumer's build directory.
# The library and consumer must agree on the LLVM (or comgr) used because
# cxx/disassembly.hpp is header-only and inlines those calls into the
# consumer's TUs.
if(@USE_LLVM_DISASM@)
    # Pin the LLVM_DIR the decoder was built with so the consumer doesn't
    # silently pick a different LLVM. Override by setting LLVM_DIR before
    # find_package(rocprof-trace-decoder).
    if(NOT DEFINED LLVM_DIR)
        set(LLVM_DIR "@LLVM_DIR@")
    endif()
    find_dependency(LLVM CONFIG)
elseif(NOT @DISABLE_COMGR@)
    # The COMGR backend is discovered with find_library/find_path and exported
    # as concrete include/library paths in rocprof-trace-decoder-targets.cmake.
    # ROCm installs do not necessarily provide amd_comgrConfig.cmake.
endif()

include("${CMAKE_CURRENT_LIST_DIR}/rocprof-trace-decoder-targets.cmake")

check_required_components(rocprof-trace-decoder)
