{
  "version": 3,
  "configurePresets": [
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "description": "Target the Windows Subsystem for Linux (WSL) or a remote system.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/_build/out/build/${presetName}",
      "installDir": "${sourceDir}/_build/out/install/${presetName}",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "vendor": { "microsoft.com/VisualStudioRemoteSettings/CMake/2.0": { "remoteSourceRootDir": "$env{HOME}/.vs/$ms{projectDirName}" } }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "description": "Target the Windows Subsystem for Linux (WSL) or a remote system.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/_build/out/build/${presetName}",
      "installDir": "${sourceDir}/_build/out/install/${presetName}",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "vendor": { "microsoft.com/VisualStudioRemoteSettings/CMake/2.0": { "remoteSourceRootDir": "$env{HOME}/.vs/$ms{projectDirName}" } }
    }
  ]
}