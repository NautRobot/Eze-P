ARG DISTRO=rockylinux/rockylinux
ARG VERSION=8
FROM ${DISTRO}:${VERSION}

ENV HOME /root
ENV SHELL /bin/bash
ENV BASH_ENV /etc/bash.bashrc
ENV DEBIAN_FRONTEND noninteractive

WORKDIR /tmp
SHELL [ "/bin/bash", "-c" ]

ENV PATH /usr/lib64/openmpi/bin:/usr/local/bin:${PATH}
ENV LIBRARY_PATH ${LIBRARY_PATH}:/opt/amdgpu/lib64

RUN yum groupinstall -y "Development Tools" && \
    yum install -y epel-release && crb enable && \
    yum install -y --allowerasing chrpath cmake curl dpkg-devel gmock-devel gtest-devel \
        iproute json-devel libdrm-devel ninja-build numactl-devel openmpi-devel \
        papi-devel python3-pip sqlite-devel wget which zlib-devel ucx-devel && \
    yum clean all && \
    python3 -m pip install --upgrade pip && \
    python3 -m pip install 'cmake==3.25' && \
    python3 -m pip install 'perfetto'

ARG ROCM_VERSION=0.0
ARG ROCM_MAJOR=0
ARG ROCM_MINOR=0
ARG ROCM_PATCH=0
ARG ROCM_VERSION_URL=0.0
ARG ROCM_VERSN=0

# Use only the major OS version in the ROCm repo URL (el8/el9/el10).
# The Rocky Linux base image uses a floating tag (e.g. :9) that resolves to
# the latest point release, and AMD does not publish repo packages for every
# minor version. The major-version path is stable across all point releases.
RUN if [ "${ROCM_MAJOR}" != "0" ] || [ "${ROCM_MINOR}" != "0" ]; then \
        OS_VERSION_MAJOR=$(grep '^VERSION_ID=' /etc/os-release | cut -d'=' -f2 | tr -d '"' | cut -d. -f1) && \
        printf '%s\n' '[rocm]' \
            "name=ROCm ${ROCM_VERSION_URL} repository" \
            "baseurl=https://repo.radeon.com/rocm/el${OS_VERSION_MAJOR}/${ROCM_VERSION_URL}/main" \
            'enabled=1' 'priority=50' 'gpgcheck=1' \
            'gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key' > /etc/yum.repos.d/rocm.repo && \
        if [ "${OS_VERSION_MAJOR}" -eq 8 ]; then PERL_REPO=powertools; else PERL_REPO=crb; fi && \
        dnf -y --enablerepo=${PERL_REPO} install perl-File-BaseDir && \
        dnf install -y rocm-dev && \
        dnf clean all; \
    fi

ARG PYTHON_VERSIONS="8 9 10 11 12 13"

# Install pytest test dependencies into each conda env
COPY requirements.txt /tmp/requirements.txt
RUN wget https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O miniforge.sh && \
    bash miniforge.sh -b -p /opt/conda && \
    export PATH="/opt/conda/bin:${PATH}" && \
    conda config --set always_yes yes --set changeps1 no --set solver classic && \
    conda update -c conda-forge -n base conda && \
    for i in ${PYTHON_VERSIONS}; do \
        conda create -n py3.${i} -c conda-forge python=3.${i} pip && \
        /opt/conda/envs/py3.${i}/bin/python -m pip install -r /tmp/requirements.txt; \
    done && \
    conda clean -a -y && \
    conda init

# Install pytest test dependencies for system python
RUN if python3 -c "import sys; sys.exit(0 if sys.version_info >= (3, 8) else 1)"; then \
        python3 -m pip install -r /tmp/requirements.txt; \
    else \
        echo "Skipping system Python install: $(python3 --version 2>&1) is too old (rocprofiler-systems test suite requires >=3.8)"; \
    fi && \
    rm -f /tmp/requirements.txt

RUN if [ "${ROCM_VERSION}" != "0.0" ]; then ln -sf /opt/rocm-${ROCM_VERSION}* /opt/rocm; fi

WORKDIR /home
ENV LC_ALL C.UTF-8
SHELL [ "/bin/bash", "--login", "-c" ]
COPY ./docker/entrypoint-rhel.sh /docker-entrypoint.sh
ENTRYPOINT [ "/docker-entrypoint.sh" ]
