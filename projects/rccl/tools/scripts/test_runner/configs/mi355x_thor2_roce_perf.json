{
  "system_configurations": {
    "name": "RCCL-Validate-MI355X-Perf",
    "description": "rccl-tests perf sweep for MI355X: 11 collectives x 12 datatypes (1B-4G)."
  },
  "paths": {
    "workdir": "${WORKDIR:-$PWD}",
    "rocm_path": "${ROCM_PATH:-/opt/rocm}",
    "mpi_path": "${MPI_PATH:-/opt/ompi}",
    "test_binary_dir": "${RCCL_TEST_BIN_DIR:-${RCCL_TESTS_DIR:-$HOME/rccl-tests}/build}"
  },
  "env_variables": {
    "NCCL_CUMEM_ENABLE": "1",
    "HSA_NO_SCRATCH_RECLAIM": "1",
    "RCCL_MSCCL_ENABLE": "0",
    "NCCL_DEBUG": "INFO",
    "NCCL_SOCKET_IFNAME": "fenic0,enp49s0f0np0",
    "NCCL_IB_HCA": "bnxt_re0,bnxt_re1,bnxt_re2,bnxt_re3,bnxt_re4,bnxt_re5,bnxt_re6,bnxt_re7",
    "NCCL_IB_TC": "104",
    "NCCL_IGNORE_CPU_AFFINITY": "1",
    "NCCL_DEBUG_SUBSYS": "NET,INIT,COLL,TUNING"
  },
  "mpi_args": [
    "--mca pml ob1",
    "--mca btl ^openib",
    "--mca plm_rsh_no_tree_spawn 1",
    "--mca oob_tcp_if_include 10.190.0.0/16",
    "--mca btl_tcp_if_include 10.190.0.0/16",
    "--bind-to none"
  ],
  "build_configuration": {
    "install_flags": [
      "--debug",
      "-t",
      "-l",
      "--log-trace",
      "--enable-code-coverage",
      "--enable-mpi-tests",
      "--no_clean"
    ],
    "cmake_options": "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DEMIT_LLVM_IR=OFF -DBITCODE_LIB_ARCH=gfx950",
    "parallel_jobs": 64
  },
  "rccl_tests_build_configuration": {
    "enabled": true,
    "source_dir": "${RCCL_TESTS_DIR:-${WORKDIR}/../rccl-tests}",
    "install_script": "install.sh",
    "install_flags": [
      "--mpi",
      "--enable-device-api",
      "--gpu_targets",
      "gfx950"
    ],
    "rccl_home": "${RCCL_HOME:-${WORKDIR}/build/debug}",
    "env_variables": {}
  },
  "test_configurations": {
    "perf_base": {
      "is_gtest": false,
      "num_nodes": 1,
      "num_gpus": 4,
      "num_ranks": 4,
      "timeout": 1200,
      "command_args": "-b 1 -e 4G -f 2 -g 1 -n 100 -w 20 -N 6 -A 1",
      "env_variables": {
        "NCCL_LAUNCH_MODE": "GROUP"
      }
    },
    "all_reduce_perf": {
