{
  "system_configurations": {
    "name": "RCCL-Perf-MI455X",
    "description": "RCCL perf sweep: 11 collectives x 12 datatypes (mi455 / MNNVL)"
  },
  "paths": {
    "workdir": "${WORKDIR:-$PWD}",
    "rocm_path": "${ROCM_PATH:-/opt/rocm}",
    "mpi_path": "${MPI_PATH:-$HOME/ompi}",
    "test_binary_dir": "${RCCL_TEST_BIN_DIR:-${RCCL_TESTS_DIR:-$HOME/rccl-tests}/build}"
  },
  "env_variables": {
    "NCCL_CUMEM_ENABLE": "1",
    "NCCL_MNNVL_ENABLE": "1",
    "RCCL_USE_AMD_SMI_LIB": "0",
    "HSA_NO_SCRATCH_RECLAIM": "1",
    "RCCL_MSCCL_ENABLE": "0",
    "NCCL_DEBUG": "VERSION"
  },
  "mpi_args": [
    "--mca pml ob1",
    "--mca btl ^openib",
    "--mca rmaps_base_oversubscribe 1",
    "--bind-to none"
  ],
  "build_configuration": {
    "enabled": false,
    "_comment": "perf binaries come from rccl_tests_build_configuration / external build"
  },
  "test_configurations": {
    "perf_base": {
      "is_gtest": false,
      "num_nodes": 1,
      "num_gpus": 4,
      "num_ranks": 4,
      "timeout": 1200,
      "command_args": "-b 1 -e 4G -f 2 -g 1 -n 100 -w 20 -N 6 -A 1",
      "env_variables": {
        "NCCL_LAUNCH_MODE": "GROUP"
      }
    },
