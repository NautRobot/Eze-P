LIBRARY hsa-amd-aqlprofile64
EXPORTS
    ; Legacy HSA vendor extension API
    hsa_ven_amd_aqlprofile_version_major
    hsa_ven_amd_aqlprofile_version_minor
    hsa_ven_amd_aqlprofile_error_string
    hsa_ven_amd_aqlprofile_validate_event
    hsa_ven_amd_aqlprofile_start
    hsa_ven_amd_aqlprofile_stop
    hsa_ven_amd_aqlprofile_read
    hsa_ven_amd_aqlprofile_legacy_get_pm4
    hsa_ven_amd_aqlprofile_get_info
    hsa_ven_amd_aqlprofile_iterate_data
    hsa_ven_amd_aqlprofile_iterate_event_ids
    hsa_ven_amd_aqlprofile_iterate_event_coord
    hsa_ven_amd_aqlprofile_att_marker

    ; AQLProfile v2 API - PMC counters
    aqlprofile_get_version
    aqlprofile_pmc_create_packets
    aqlprofile_pmc_delete_packets
    aqlprofile_pmc_iterate_data
    aqlprofile_iterate_event_ids
    aqlprofile_iterate_event_coord
    aqlprofile_register_agent
    aqlprofile_register_agent_info
    aqlprofile_validate_pmc_event
    aqlprofile_get_pmc_info

    ; AQLProfile v2 API - SPM
    aqlprofile_spm_create_packets
    aqlprofile_spm_delete_packets
    aqlprofile_spm_start
    aqlprofile_spm_stop
    aqlprofile_spm_decode_query
    aqlprofile_spm_decode_stream_v1
    aqlprofile_spm_is_event_supported

    ; AQLProfile v2 API - ATT (thread trace)
    aqlprofile_att_create_packets
    aqlprofile_att_delete_packets
    aqlprofile_att_iterate_data
    aqlprofile_att_get_buffer_packets
    aqlprofile_att_update_buffer_status
    aqlprofile_att_codeobj_marker
