{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "pragma",
      "syntax",
      "description",
      "gpu_applicable",
      "allowlist",
      "trigger_signal",
      "trigger_threshold",
      "factor_sweep",
      "expected_impact",
      "risk",
      "source_citation",
      "applies_to_gfx"
    ],
    "properties": {
      "pragma": {
        "type": "string"
      },
      "syntax": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "gpu_applicable": {
        "type": "boolean"
      },
      "allowlist": {
        "type": "boolean"
      },
      "trigger_signal": {
        "type": "string"
      },
      "trigger_threshold": {
        "type": "string"
      },
      "factor_sweep": {
        "type": "array",
        "items": {
          "type": "integer"
        }
      },
      "expected_impact": {
        "type": "string"
      },
      "risk": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ]
      },
      "source_citation": {
        "type": "string"
      },
      "applies_to_gfx": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
