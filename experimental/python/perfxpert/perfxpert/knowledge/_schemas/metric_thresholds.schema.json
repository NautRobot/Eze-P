{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "patternProperties": {
    "^[a-z_][a-z0-9_]*$": {
      "type": "object",
      "required": ["high", "medium", "low", "unit"],
      "properties": {
        "high": {"type": "number"},
        "medium": {"type": "number"},
        "low": {"type": "number"},
        "unit": {"type": "string"},
        "description": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
