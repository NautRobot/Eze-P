{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "wave_issued", "meaning", "interpretation"],
    "properties": {
      "name": {"type": "string", "enum": ["ISSUED", "LATENCY", "INDETERMINATE"]},
      "wave_issued": {"type": "integer", "enum": [0, 1]},
      "meaning": {"type": "string"},
      "interpretation": {"type": "string"},
      "actionable": {"type": "boolean"}
    },
    "additionalProperties": false
  }
}
